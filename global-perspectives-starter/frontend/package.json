{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "eslint . --max-warnings 20",
    "build": "vite build",
    "postbuild": "cp dist/index.html dist/404.html",
    "lint": "eslint .",
    "verify": "eslint . && vitest run",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@aws-amplify/api-graphql": "^4.8.8",
    "@chenglou/pretext": "^0.0.8",
    "@googlemaps/react-wrapper": "^1.2.0",
    "aws-amplify": "^6.18.0",
    "d3": "^7.9.0",
    "driver.js": "^1.4.0",
    "firebase": "^12.15.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^6.30.1",
    "topojson-client": "^3.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@playwright/test": "^1.61.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "axe-core": "^4.12.1",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^16.4.0",
    "jsdom": "^29.1.1",
